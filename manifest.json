{
    "manifest_version": 3,
    "name": "Reddit Improvement Zzuite (RIZz)",
    "version": "0.3.8",
    "description": "Enhances/improves Reddit by giving users tools to curate their own experience on the site.",
    "icons": {
        "32": "/images/duck@32.png",
        "64": "/images/duck@64.png"
    },
    "permissions": [
        "storage"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "jordantrenholm@outlook.com",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.reddit.com/*"
            ],
            "js": [
                "definitions.js",
                "utils.js",
                "state.js",
                "shortcut.js",
                "tooltips.js",
                "links.js",
                "customCss.js",
                "filter.js",
                "init.js"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_start"
        }
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "action": {
        "default_icon": {
            "32": "/images/duck@32.png",
            "64": "/images/duck@64.png"
        },
        "default_popup": "options.html"
    }
}